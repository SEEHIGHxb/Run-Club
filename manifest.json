{
  "name": "Runaway",
  "short_name": "Runaway",
  "description": "Live group run tracker and challenge dashboard.",
  "start_url": "./",
  "scope": "./",
  "display": "standalone",
  "background_color": "#f9f9f9",
  "theme_color": "#ff0000",
  "icons": [
    { "src": "./icons/runorlose.png", "sizes": "192x192", "type": "image/png", "purpose": "any" },
    { "src": "./icons/runorlose.png", "sizes": "512x512", "type": "image/png", "purpose": "any maskable" }
  ],
  "share_target": {
    "action": "./share-target",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "files": [
        {
          "name": "file",
          "accept": [
            "application/octet-stream",
            ".fit",
            ".tcx",
            ".gpx",
            "application/gpx+xml",
            "application/vnd.ant.fit",
            "application/vnd.garmin.tcx+xml",
            "text/xml",
            "application/xml"
          ]
        }
      ]
    }
  }
}
